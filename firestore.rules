rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.toLower() == 'abhinaynachankar7@gmail.com' ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true
      );
    }
    function isMember(roomId) {
      return exists(/databases/$(database)/documents/room_members/$(roomId + '_' + request.auth.uid));
    }

    // 1. Profiles: Readable by all authenticated users, writable by owner or admin
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      match /unread_dms/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null;
      }
    }

    // 1b. Friend Requests
    match /friend_requests/{reqId} {
      allow read: if request.auth != null && (
        resource.data.from_uid == request.auth.uid ||
        resource.data.to_uid   == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.from_uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.to_uid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.from_uid == request.auth.uid ||
        resource.data.to_uid   == request.auth.uid
      );
    }

    // 2. Admin Collections: Only admins can access
    match /payments/{paymentId} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null; 
      allow update, delete: if false; 
    }
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /support_tickets/{ticketId} {
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if request.auth != null && isAdmin();
    }

    // 2. User-scoped collections: read docs where user_id == auth uid, write if setting user_id to own uid
    match /sessions/{docId} {
      allow read: if request.auth != null && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.user_id == request.auth.uid || isAdmin());
    }
    match /tasks/{docId} {
      allow read: if request.auth != null && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.user_id == request.auth.uid || isAdmin());
    }
    match /notes/{docId} {
      allow read: if request.auth != null && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && (resource.data.user_id == request.auth.uid || isAdmin());
    }
    match /notifications/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    match /resumes/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    // 3. Collaborative Study Rooms — Membership Restricted
    match /study_rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (isMember(roomId) || resource.data.created_by == request.auth.uid || isAdmin());
    }
    match /room_members/{memberId} {
      allow read: if request.auth != null && (resource.data.user_id == request.auth.uid || isMember(resource.data.room_id));
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    match /room_messages/{messageId} {
      allow read: if request.auth != null && isMember(resource.data.room_id);
      allow create: if request.auth != null && isMember(request.resource.data.room_id);
      // Allow the message author OR any room member with owner status to update (for pinning)
      allow update: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        isMember(resource.data.room_id)
      );
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
    match /room_whiteboard/{whiteboardId} {
      allow read: if request.auth != null && isMember(resource.data.room_id);
      allow create: if request.auth != null && isMember(request.resource.data.room_id);
      allow update, delete: if request.auth != null && isMember(resource.data.room_id);
    }
    match /room_tasks/{taskId} {
      allow read: if request.auth != null && isMember(resource.data.room_id);
      allow create: if request.auth != null && isMember(request.resource.data.room_id);
      allow update, delete: if request.auth != null && isMember(resource.data.room_id);
    }
    match /room_events/{eventId} {
      allow read: if request.auth != null && isMember(resource.data.room_id);
      allow create: if request.auth != null && isMember(request.resource.data.room_id);
      allow update, delete: if request.auth != null && isMember(resource.data.room_id);
    }
    // Discord-style channels for each room
    match /room_channels/{channelId} {
      allow read: if request.auth != null && isMember(resource.data.room_id);
      allow create: if request.auth != null && isMember(request.resource.data.room_id);
      allow update, delete: if request.auth != null && isMember(resource.data.room_id);
    }
    // Voice channel presence (who is in voice)
    match /room_voice_presence/{presenceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null;
    }
    // WebRTC signaling for voice channels
    match /room_voice_signals/{signalId} {
      allow read, write, delete: if request.auth != null;
    }
    // Collaborative docs per channel
    match /room_docs/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /promo_codes/{docId} {
      allow read, write: if true;
    }

    match /room_typing/{typingId} {
      allow read: if request.auth != null && isMember(resource.data.room_id);
      allow create: if request.auth != null && isMember(request.resource.data.room_id);
      allow update, delete: if request.auth != null && isMember(resource.data.room_id);
    }

    // Direct Messages — only the two participants (whose UIDs form the conversation ID) can access
    match /dms/{convoId} {
      allow read, write: if request.auth != null && convoId.matches('.*' + request.auth.uid + '.*');
      match /messages/{msgId} {
        allow read: if request.auth != null && convoId.matches('.*' + request.auth.uid + '.*');
        allow create: if request.auth != null && convoId.matches('.*' + request.auth.uid + '.*') && request.resource.data.from == request.auth.uid;
        allow delete: if request.auth != null && resource.data.from == request.auth.uid;
      }
    }
  }
}
